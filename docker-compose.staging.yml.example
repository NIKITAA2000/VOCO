version: "3.8"

# Staging-окружение: voco.su
# Скопируй этот файл: cp docker-compose.staging.yml.example docker-compose.staging.yml
# Замени все CHANGE_ME_* на реальные значения

services:
  postgres-staging:
    image: postgres:15
    container_name: voco-postgres-staging
    restart: always
    environment:
      POSTGRES_USER: voco_staging
      POSTGRES_PASSWORD: CHANGE_ME_STAGING_DB_PASSWORD
      POSTGRES_DB: voco_staging_db
    volumes:
      - postgres_staging_data:/var/lib/postgresql/data
    networks:
      - voco-net

  livekit-staging:
    image: livekit/livekit-server:latest
    container_name: voco-livekit-staging
    restart: always
    command: --config /etc/livekit.yaml
    ports:
      - "7890:7880"
      - "7891:7881"
      - "7892:7882"
      - "50100-50160:50000-50060/udp"
    volumes:
      - ./livekit.staging.yaml:/etc/livekit.yaml
    networks:
      - voco-net

  backend-staging:
    build:
      context: ./backend
      dockerfile: Dockerfile
    container_name: voco-backend-staging
    restart: always
    environment:
      PORT: 3002
      NODE_ENV: production
      JWT_SECRET: CHANGE_ME_STAGING_JWT_SECRET
      LIVEKIT_API_KEY: voco_staging_key
      LIVEKIT_API_SECRET: CHANGE_ME_STAGING_LIVEKIT_SECRET
      LIVEKIT_URL: ws://voco-livekit-staging:7880
      LIVEKIT_PUBLIC_URL: wss://voco.su/livekit/
      CORS_ORIGIN: https://voco.su
      DATABASE_URL: postgresql://voco_staging:CHANGE_ME_STAGING_DB_PASSWORD@voco-postgres-staging:5432/voco_staging_db
    depends_on:
      - postgres-staging
      - livekit-staging
    networks:
      - voco-net

volumes:
  postgres_staging_data:

networks:
  voco-net:
    external: true
    name: voco_default
